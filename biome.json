{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"files": {
		"includes": [
			"packages/**",
			"*.json",
			"*.yaml",
			"!**/node_modules",
			"!**/dist"
		]
	}
}
